{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for MindWork AI Studio",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "updater:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "mindworkAIStudioServer",
          "sidecar": true,
          "args": true
        },
        {
          "name": "qdrant",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
